# Notifications
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_URL_NGO=
DISCORD_BOT_TOKEN=
DISCORD_COMMAND_CHANNEL_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Scheduling
SCAN_INTERVAL_MINUTES=45
DIGEST_INTERVAL_HOURS=6

# Filters
LOCATION_ALLOWLIST=worldwide,eu,europe,germany,berlin,remote
LOCATION_BLOCKLIST=uk only,united kingdom,london,us only,canada only
MIN_NGO_SCORE=1

# Company blocklist — comma-separated company names to always skip
COMPANY_BLOCKLIST=TechBiz Global,Lemon.io,A.Team,Zipdev,Turing,Toptal

# Optional quality filters (off by default)
FILTER_SENIOR_ONLY=false
MIN_SALARY_EUR=0

# Concurrency
MAX_CONCURRENT_SOURCES=6

# Health endpoint
HEALTH_PORT=8080

# Database
DATABASE_PATH=./data/jobs.db

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/job_bot.log
